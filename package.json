{
  "name": "cache-nexus",
  "private": true,
  "workspaces": [
    "lib/*",
    "artifacts/api-server",
    "artifacts/api-server/student-platform"
  ],
  "scripts": {
    "install:all": "pnpm install",
    "build": "pnpm --recursive --parallel run build",
    "dev:api": "pnpm --filter api-server run dev",
    "dev:frontend": "pnpm --filter student-platform run dev"
  },
  "devDependencies": {
    "pnpm": "^8.0.0"
  }
}